APP_NAME=AGROPAY
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Maputo

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=agropay_db
DB_USERNAME=agropay
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@agropay.mz
MAIL_FROM_NAME="AGROPAY"

JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_TTL=60

PAYMENT_GATEWAY_MPESA_API_KEY=
PAYMENT_GATEWAY_MPESA_API_SECRET=
PAYMENT_GATEWAY_EMOLA_API_KEY=
PAYMENT_GATEWAY_EMOLA_API_SECRET=

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
TRUSTED_PROXIES=*

WEBHOOK_RETRY_ATTEMPTS=5
WEBHOOK_RETRY_DELAY=300

LOG_CHANNEL=single
LOG_LEVEL=debug
